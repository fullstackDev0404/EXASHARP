{
  "name": "exasharp",
  "version": "0.0.0",
  "description": "An ERP web hosting SAAS application.",
  "keywords": [
    "ERP"
  ],
  "homepage": "https://github.com/fullstackDev0404/EXASHARP#readme",
  "bugs": {
    "url": "https://github.com/fullstackDev0404/EXASHARP/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fullstackDev0404/EXASHARP.git"
  },
  "license": "ISC",
  "author": "Joana kelly & Sadik Ahsan",
  "type": "commonjs",
  "main": "index.js",
"scripts": {
    "install-all": "npm install --prefix server && npm install --prefix client",
    "server": "nodemon server/app.js",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run install-all && npm run build --prefix client",
    "start": "nodemon server/app.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10"
  }
}
