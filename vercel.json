{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "server/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/client/.svelte-kit/output/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server/app.js"
    }
  ],
  "outputDirectory": "client/.svelte-kit/output"
}
