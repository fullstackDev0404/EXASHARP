# Bun & Dependencies
node_modules/
bun.lockb
# If you are strictly using Bun, you can ignore these NPM/Yarn files:
package-lock.json
yarn.lock
pnpm-lock.yaml

# SvelteKit & Frontend (Vite)
.svelte-kit/
/build/
/out/
/dist/
.vercel/
.netlify/
.wrangler/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Elysia & Backend
# (Elysia usually outputs to dist/ or build/, covered above)
# Add any specific binary outputs if you compile with 'bun build --compile'
*.exe
*.o

# Environment & Secrets (CRITICAL)
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
